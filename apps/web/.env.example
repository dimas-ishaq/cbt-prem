# Web App
# Copy to .env.local for local dev or set on VPS.

# Public URL for browser redirects, SEO, and absolute links.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public API base URL.
# Local dev: http://localhost:3001/api
# Production: https://api.novatech.biz.id/api
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Optional: enable app-wide debug logging.
NEXT_PUBLIC_DEBUG=false
