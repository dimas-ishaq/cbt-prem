# Web Environment (deploy ready)
# Copy to .env.local for local dev or VPS.

# Public app URL
NEXT_PUBLIC_APP_URL=https://novatech.biz.id

# Public API base URL
NEXT_PUBLIC_API_URL=https://api.novatech.biz.id/api

# Public websocket URL
NEXT_PUBLIC_WS_URL=https://api.novatech.biz.id

# Optional debug flag
NEXT_PUBLIC_DEBUG=false
