# API Environment
# Copy to .env.local for local dev or set on VPS.

# JWT signing secret. Use long random string.
JWT_SECRET=change-me-long-random-secret

# JWT refresh signing secret. Use different long random string.
JWT_REFRESH_SECRET=change-me-long-random-refresh-secret

# Refresh token lifetime.
JWT_REFRESH_EXPIRES_IN=7d

# Postgres connection.
DATABASE_URL=postgresql://user:password@localhost:5432/cbt_db?schema=public

# Allowed browser origins.
# Local: http://localhost:3000
# Production: https://novatech.biz.id,https://api.novatech.biz.id
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# API listen port.
PORT=3001

# Runtime mode.
NODE_ENV=production

# Redis connection.
REDIS_URL=redis://localhost:6379

# Frontend public URL.
FRONTEND_URL=https://novatech.biz.id
