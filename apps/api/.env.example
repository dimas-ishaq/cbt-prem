# API Environment (deploy ready)
# Copy to .env for VPS or local dev.

# App runtime
NODE_ENV=production
PORT=3001

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/cbt_db?schema=public

# Auth
JWT_SECRET=replace-with-long-random-secret-1
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=replace-with-long-random-secret-2
JWT_REFRESH_EXPIRES_IN=7d

# CORS / browser origin
# Local: http://localhost:3000
# Production: https://novatech.biz.id,https://api.novatech.biz.id
CORS_ORIGIN=http://localhost:3000,http://localhost:3001:3000,https://novatech.biz.id,https://api.novatech.biz.id

# Public frontend URL
FRONTEND_URL=https://novatech.biz.id

# Optional public API URL for web/client helpers
PUBLIC_API_URL=https://api.novatech.biz.id/api

# Redis
REDIS_URL=redis://localhost:6379
